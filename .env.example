VITE_PUBLIC_SUPABASE_ANON_KEY=
VITE_PUBLIC_SUPABASE_URL=

ANTHROPIC_API_KEY=

# Paddle (기존 유저 지원용 — 신규 유저는 Lemon Squeezy 사용)
VITE_PADDLE_CLIENT_TOKEN=
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=

# Paddle Price IDs (set after creating prices in Paddle dashboard)
VITE_PADDLE_PRICE_STARTER_MONTHLY=
VITE_PADDLE_PRICE_STARTER_ANNUAL=
VITE_PADDLE_PRICE_PROFESSIONAL_MONTHLY=
VITE_PADDLE_PRICE_PROFESSIONAL_ANNUAL=
VITE_PADDLE_PRICE_ENTERPRISE_S_MONTHLY=
VITE_PADDLE_PRICE_ENTERPRISE_S_ANNUAL=
VITE_PADDLE_PRICE_ENTERPRISE_M_MONTHLY=
VITE_PADDLE_PRICE_ENTERPRISE_M_ANNUAL=

# Lemon Squeezy (신규 결제 제공자)
VITE_LEMON_STORE_ID=                     # Lemon Squeezy 스토어 slug (예: testably)
LEMON_API_KEY=                           # Lemon Squeezy API Key (백엔드용)
# LEMON_WEBHOOK_SECRET — Supabase Secrets에 등록 (코드/파일에 기록하지 않음)

# ── Monitoring ────────────────────────────────────────────────────────────────

# Sentry (에러 트래킹) — https://sentry.io
# Kyle이 프로젝트 생성 후 Project Settings > Client Keys(DSN)에서 복사
VITE_SENTRY_DSN=

# Sentry source map 업로드용 (CI/Vercel 빌드에서만 사용)
# Kyle이 Sentry > Settings > Auth Tokens에서 발급
SENTRY_AUTH_TOKEN=
SENTRY_ORG=                              # Sentry organization slug
SENTRY_PROJECT=                          # Sentry project slug

# BetterStack (Uptime 모니터링) — https://betterstack.com
# smoke 테스트 통과 시 ping하는 heartbeat URL
# Kyle이 Heartbeats 메뉴에서 새 heartbeat 생성 후 URL 복사
BETTERSTACK_HEARTBEAT_URL=

# Playwright Smoke Tests (GitHub Actions Secrets에 등록)
# 아래 값은 .env 파일에 넣지 말고 GitHub > Settings > Secrets에 저장
SMOKE_TEST_EMAIL=                        # 전용 smoke test 계정 이메일
SMOKE_TEST_PASSWORD=                     # smoke test 계정 비밀번호
SMOKE_PROJECT_ID=                        # smoke test용 전용 프로젝트 UUID
SMOKE_BASE_URL=https://testably.app      # 모니터링 대상 URL
