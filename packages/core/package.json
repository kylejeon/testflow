{
  "name": "@testably/reporter-core",
  "version": "0.1.0-alpha.0",
  "description": "Core API client for Testably reporters — handles upload, retry, rate limiting, and TC ID mapping",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "testably",
    "reporter",
    "ci",
    "test-automation"
  ],
  "license": "MIT",
  "author": "Testably",
  "homepage": "https://github.com/kylejeon/testflow/tree/main/packages/core#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kylejeon/testflow.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/kylejeon/testflow/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.4"
  }
}
