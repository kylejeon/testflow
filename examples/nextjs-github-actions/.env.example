# Testably reporter required env vars.
# Copy this file to .env and fill in the real values.
# In CI, set these as GitHub repository secrets instead.

# Testably host (use app.testably.app for production workspaces).
TESTABLY_URL=https://app.testably.app

# Workspace CI/CD token. Generate at:
# Testably → Settings → CI/CD Tokens → "Create token"
TESTABLY_TOKEN=testably_

# Run ID to upload results into. Create a run in Testably and copy the UUID
# from the URL (e.g. /runs/abcd1234-5678-...).
TESTABLY_RUN_ID=

# Optional: uncomment to validate auth/run id without writing any data.
# TESTABLY_DRY_RUN=true
